\newlabel{fig:mnar-gamma}{{4a}{11}{Posterior density of $\gamma $ under three prior widths $\sigma _\gamma \in \{0.5, 1.0, 2.0\}$. Solid lines show posteriors; dashed lines show the $\mathcal {N}(0, \sigma _\gamma ^2)$ priors. The vertical dashed line at $\gamma = 0$ marks MAR. All posteriors are decisively negative}{figure.caption.4}{}}
\newlabel{sub@fig:mnar-gamma}{{a}{11}{Posterior density of $\gamma $ under three prior widths $\sigma _\gamma \in \{0.5, 1.0, 2.0\}$. Solid lines show posteriors; dashed lines show the $\mathcal {N}(0, \sigma _\gamma ^2)$ priors. The vertical dashed line at $\gamma = 0$ marks MAR. All posteriors are decisively negative}{figure.caption.4}{}}
\newlabel{fig:emergency}{{4b}{11}{Posterior density of $\beta _{\text {emergency}}$ under MAR (grey) and three MNAR specifications. The MAR estimate (0.902) attenuates to 0.558 under $\sigma _\gamma = 2$, yet remains decisively positive}{figure.caption.4}{}}
\newlabel{sub@fig:emergency}{{b}{11}{Posterior density of $\beta _{\text {emergency}}$ under MAR (grey) and three MNAR specifications. The MAR estimate (0.902) attenuates to 0.558 under $\sigma _\gamma = 2$, yet remains decisively positive}{figure.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces MNAR sensitivity analysis: \textbf  {(a)}~inferred selection parameter $\gamma $ across prior widths, and \textbf  {(b)}~resulting attenuation of the emergency admission covariate effect.}}{11}{figure.caption.4}\protected@file@percent }
\newlabel{fig:mnar-sensitivity}{{4}{11}{MNAR sensitivity analysis: \textbf {(a)}~inferred selection parameter $\gamma $ across prior widths, and \textbf {(b)}~resulting attenuation of the emergency admission covariate effect}{figure.caption.4}{}}
