\newlabel{fig:mnar-gamma}{{3a}{10}{Posterior density of $\gamma $}{figure.caption.3}{}}
\newlabel{sub@fig:mnar-gamma}{{a}{10}{Posterior density of $\gamma $}{figure.caption.3}{}}
\newlabel{fig:emergency}{{3b}{10}{Posterior of $\beta _{\text {emergency}}$}{figure.caption.3}{}}
\newlabel{sub@fig:emergency}{{b}{10}{Posterior of $\beta _{\text {emergency}}$}{figure.caption.3}{}}
\newlabel{fig:survival}{{3c}{10}{Population-averaged survival $S(t)$}{figure.caption.3}{}}
\newlabel{sub@fig:survival}{{c}{10}{Population-averaged survival $S(t)$}{figure.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces MNAR sensitivity analysis: \textbf  {(a)}~Inferred selection parameter $\gamma $ under three prior widths $\sigma _\gamma \in \{0.5, 1.0, 2.0\}$. Solid lines show posteriors; dashed lines show the $\mathcal  {N}(0, \sigma _\gamma ^2)$ priors, and the vertical line at $\gamma = 0$ marks MAR (all posteriors are decisively negative). \textbf  {(b)}~Resulting attenuation of the emergency admission covariate effect under MAR (grey) and three MNAR specifications. The MAR estimate (0.902) attenuates to 0.558 under $\sigma _\gamma = 2$, yet remains decisively positive. \textbf  {(c)}~Population-averaged survival $S(t)$ comparing MAR and varying MNAR assumptions. Transparent curves show 200 posterior draws per model; bold lines show posterior means. The MAR draws (grey) and Kaplan--Meier (dashed black) closely track through day~10. Colored draw-clouds show MNAR-adjusted survival; wider priors produce larger shifts and wider posterior spread.}}{10}{figure.caption.3}\protected@file@percent }
\newlabel{fig:mnar-sensitivity}{{3}{10}{MNAR sensitivity analysis: \textbf {(a)}~Inferred selection parameter $\gamma $ under three prior widths $\sigma _\gamma \in \{0.5, 1.0, 2.0\}$. Solid lines show posteriors; dashed lines show the $\mathcal {N}(0, \sigma _\gamma ^2)$ priors, and the vertical line at $\gamma = 0$ marks MAR (all posteriors are decisively negative). \textbf {(b)}~Resulting attenuation of the emergency admission covariate effect under MAR (grey) and three MNAR specifications. The MAR estimate (0.902) attenuates to 0.558 under $\sigma _\gamma = 2$, yet remains decisively positive. \textbf {(c)}~Population-averaged survival $S(t)$ comparing MAR and varying MNAR assumptions. Transparent curves show 200 posterior draws per model; bold lines show posterior means. The MAR draws (grey) and Kaplan--Meier (dashed black) closely track through day~10. Colored draw-clouds show MNAR-adjusted survival; wider priors produce larger shifts and wider posterior spread}{figure.caption.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Posterior means, standard deviations (SD), effective sample sizes (ESS), and the frailty attenuation difference ($\Delta $) for covariate effects. Both models exhibited excellent MCMC convergence (all $\hat  {R} \le 1.01$, zero divergent transitions). Model~B additionally estimates the frailty standard deviation ($\sigma _b$).}}{10}{table.caption.5}\protected@file@percent }
\newlabel{tab:master_results}{{2}{10}{Posterior means, standard deviations (SD), effective sample sizes (ESS), and the frailty attenuation difference ($\Delta $) for covariate effects. Both models exhibited excellent MCMC convergence (all $\hat {R} \le 1.01$, zero divergent transitions). Model~B additionally estimates the frailty standard deviation ($\sigma _b$)}{table.caption.5}{}}
