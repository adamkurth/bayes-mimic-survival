\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Baseline characteristics of the MIMIC-III analytic cohort within the 30-day observation window, stratified by outcome. \emph  {Discharged} denotes patients censored alive before the window closes (the clinically informative censoring mechanism); \emph  {Survived} denotes patients still alive at 30 days (administratively censored). Values are $n$ (\%) for categorical variables and mean $\pm $ SD or median [IQR] for continuous variables.}}{17}{table.3}\protected@file@percent }
\newlabel{tab:cohort}{{3}{17}{Baseline characteristics of the MIMIC-III analytic cohort within the 30-day observation window, stratified by outcome. \emph {Discharged} denotes patients censored alive before the window closes (the clinically informative censoring mechanism); \emph {Survived} denotes patients still alive at 30 days (administratively censored). Values are $n$ (\%) for categorical variables and mean $\pm $ SD or median [IQR] for continuous variables}{table.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Summary of the discrete-time data structure within the 30-day observation window ($\Delta = 1$ days, $K = 30$ intervals). Clinically censored patients are those discharged alive before 30 days; administratively censored patients survived the full window.}}{18}{table.4}\protected@file@percent }
\newlabel{tab:data-structure}{{4}{18}{Summary of the discrete-time data structure within the 30-day observation window ($\Delta = 1$ days, $K = 30$ intervals). Clinically censored patients are those discharged alive before 30 days; administratively censored patients survived the full window}{table.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Covariates in the design matrix $\mathbf  {X}$ ($P = 17$). The first nine covariates (above the rule) correspond to the simulation study; the remaining eight are additional clinical predictors. All variables except age are binary (0/1). ICD-9 codes shown in parentheses.}}{19}{table.5}\protected@file@percent }
\newlabel{tab:covariates}{{5}{19}{Covariates in the design matrix $\mathbf {X}$ ($P = 17$). The first nine covariates (above the rule) correspond to the simulation study; the remaining eight are additional clinical predictors. All variables except age are binary (0/1). ICD-9 codes shown in parentheses}{table.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Risk set composition across discrete-time intervals ($\Delta = 1$ days). \emph  {Censored} here denotes patients discharged alive during each interval. The censoring proportion among exits quantifies the rate at which the informative censoring mechanism depletes the risk set---the empirical pattern interrogated by the sensitivity parameter $\gamma $ in Section~\ref {sc:sensitivity}.}}{19}{table.6}\protected@file@percent }
\newlabel{tab:censoring-pattern}{{6}{19}{Risk set composition across discrete-time intervals ($\Delta = 1$ days). \emph {Censored} here denotes patients discharged alive during each interval. The censoring proportion among exits quantifies the rate at which the informative censoring mechanism depletes the risk set---the empirical pattern interrogated by the sensitivity parameter $\gamma $ in Section~\ref {sc:sensitivity}}{table.6}{}}
