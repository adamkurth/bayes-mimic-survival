\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Model~A diagnostics. \textbf  {(a)}~Estimated baseline hazard $h_0(t) = \text  {logit}^{-1}(\alpha _t)$ with 95\% credible interval. The hazard peaks on day~1 and declines; widening bands after day~20 reflect the shrinking risk set. \textbf  {(b)}~Risk-decile calibration. Points above the diagonal indicate over-prediction, consistent with~\eqref  {eq:bias-approx}: selective discharge inflates the predicted hazard for remaining patients.}}{8}{figure.caption.2}\protected@file@percent }
\newlabel{fig:modelA-diagnostics}{{2}{8}{Model~A diagnostics. \textbf {(a)}~Estimated baseline hazard $h_0(t) = \text {logit}^{-1}(\alpha _t)$ with 95\% credible interval. The hazard peaks on day~1 and declines; widening bands after day~20 reflect the shrinking risk set. \textbf {(b)}~Risk-decile calibration. Points above the diagonal indicate over-prediction, consistent with~\eqref {eq:bias-approx}: selective discharge inflates the predicted hazard for remaining patients}{figure.caption.2}{}}
