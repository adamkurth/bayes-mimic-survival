\newlabel{fig:baseline-hazard}{{2a}{9}{Estimated baseline hazard $h_0(t) = \text {logit}^{-1}(\alpha _t)$ under Model~A with 95\% credible interval. The hazard peaks on day~1 and declines through the first week. Widening bands after day~20 reflect the shrinking risk set}{figure.caption.2}{}}
\newlabel{sub@fig:baseline-hazard}{{a}{9}{Estimated baseline hazard $h_0(t) = \text {logit}^{-1}(\alpha _t)$ under Model~A with 95\% credible interval. The hazard peaks on day~1 and declines through the first week. Widening bands after day~20 reflect the shrinking risk set}{figure.caption.2}{}}
\newlabel{fig:calibration}{{2b}{9}{Risk-decile calibration for Model~A. Points above the diagonal indicate over-prediction, consistent with~\eqref {eq:bias-approx}: selective discharge inflates the predicted hazard for remaining patients}{figure.caption.2}{}}
\newlabel{sub@fig:calibration}{{b}{9}{Risk-decile calibration for Model~A. Points above the diagonal indicate over-prediction, consistent with~\eqref {eq:bias-approx}: selective discharge inflates the predicted hazard for remaining patients}{figure.caption.2}{}}
