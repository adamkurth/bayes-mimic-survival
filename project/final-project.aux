\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Posterior mean covariate effects (log-odds ratio for daily hazard) under Model~A and Model~B. Difference column shows the attenuation correction from including frailty.}}{10}{table.1}\protected@file@percent }
\newlabel{tab:beta-comparison}{{1}{10}{Posterior mean covariate effects (log-odds ratio for daily hazard) under Model~A and Model~B. Difference column shows the attenuation correction from including frailty}{table.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces MCMC diagnostics for covariate effects ($\hat  {\beta }$) under both models. $\hat  {R}$ values below 1.01 and ESS above 400 indicate reliable convergence. Model~B additionally estimates $\sigma _b$ (frailty SD). All chains: 0 divergent transitions.}}{11}{table.2}\protected@file@percent }
\newlabel{tab:diagnostics}{{2}{11}{MCMC diagnostics for covariate effects ($\hat {\beta }$) under both models. $\hat {R}$ values below 1.01 and ESS above 400 indicate reliable convergence. Model~B additionally estimates $\sigma _b$ (frailty SD). All chains: 0 divergent transitions}{table.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Six-panel overview of the MIMIC-III analysis. \textbf  {(a)} Estimated baseline hazard $h(t) = \text  {logit}^{-1}(\alpha _t)$ with 95\% CrI, showing an early peak followed by plateau. \textbf  {(b)} Trace of log-posterior confirming convergence. \textbf  {(c)} Forest plot of all 17 covariate effects with 95\% CrI. \textbf  {(d)} Model~A vs.\ B coefficient comparison; all points lie above the diagonal, confirming uniform attenuation correction. \textbf  {(e--f)} Sensitivity of emergency and sepsis effects to $\gamma $; both remain well above zero across the grid.}}{12}{figure.2}\protected@file@percent }
\newlabel{fig:overview}{{2}{12}{Six-panel overview of the MIMIC-III analysis. \textbf {(a)} Estimated baseline hazard $h(t) = \text {logit}^{-1}(\alpha _t)$ with 95\% CrI, showing an early peak followed by plateau. \textbf {(b)} Trace of log-posterior confirming convergence. \textbf {(c)} Forest plot of all 17 covariate effects with 95\% CrI. \textbf {(d)} Model~A vs.\ B coefficient comparison; all points lie above the diagonal, confirming uniform attenuation correction. \textbf {(e--f)} Sensitivity of emergency and sepsis effects to $\gamma $; both remain well above zero across the grid}{figure.2}{}}
