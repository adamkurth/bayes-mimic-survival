\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Sensitivity analysis for all 17 covariates. Posterior mean and 95\% CrI as a function of $\gamma $ (departure from MAR). Grey horizontal line indicates null effect. Of 17 covariates, 14 never cross zero for $\gamma \in [-1.5, 1.5]$. Only vasopressor, COPD, and dialysis have tipping points at $\gamma ^\ast = -1.5$.}}{13}{figure.3}\protected@file@percent }
\newlabel{fig:sensitivity}{{3}{13}{Sensitivity analysis for all 17 covariates. Posterior mean and 95\% CrI as a function of $\gamma $ (departure from MAR). Grey horizontal line indicates null effect. Of 17 covariates, 14 never cross zero for $\gamma \in [-1.5, 1.5]$. Only vasopressor, COPD, and dialysis have tipping points at $\gamma ^\ast = -1.5$}{figure.3}{}}
