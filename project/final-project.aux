\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Empirical follow-up distribution and risk set evolution for the MIMIC-III cohort (\(N = 57,694 ; \Delta = 1\) day, \(K=30\)). \textbf  {(a)} Histogram stratifed by outcome: death (red), discharge (blue). The dashed vertical line marks the 30-day observation window. The mode of 4--6 days reflect the typical short ICU stay; deaths are concentrated in the first two weeks. \textbf  {(b)} Risk set size (black) with cumulative discharges (blue) and deaths (red). The widening gap between cumulative rates illustrates that the risk set depletes primarily through discharge, especially in the first week. }}{8}{figure.1}\protected@file@percent }
\newlabel{fig:censoring-pattern}{{1}{8}{Empirical follow-up distribution and risk set evolution for the MIMIC-III cohort (\(N = 57,694 ; \Delta = 1\) day, \(K=30\)). \textbf {(a)} Histogram stratifed by outcome: death (red), discharge (blue). The dashed vertical line marks the 30-day observation window. The mode of 4--6 days reflect the typical short ICU stay; deaths are concentrated in the first two weeks. \textbf {(b)} Risk set size (black) with cumulative discharges (blue) and deaths (red). The widening gap between cumulative rates illustrates that the risk set depletes primarily through discharge, especially in the first week}{figure.1}{}}
